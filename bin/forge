#!/usr/bin/env bash

set -euo pipefail

FORGE_SHARE_DIR="${FORGE_SHARE_DIR:-__FORGE_SHARE_DIR__}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ ! -d "$FORGE_SHARE_DIR" ]; then
  FORGE_SHARE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
fi

usage() {
  cat <<'EOF'
Forge CLI

Usage:
  forge init [path]
  forge sync [path]
  forge exec [-- ] <command...>
  forge shell [script]
  forge status | up | push | pull | stop | down
  forge help

Commands:
  init     Open OpenCode in the target directory with `/init` preloaded.
  sync     Refresh Forge-managed files in an existing project.
           Updates docs/template.typ, docs/titlepage.typ, and reference templates.
  exec     Run a shell command inside the project's Daytona sandbox.
           Project files are uploaded before, artifacts downloaded after.
  shell    Run an inline bash command inside the sandbox (default: `bash -l`).
  status   Show the sandbox bound to the current project.
  up       Ensure the sandbox exists, sync the project up.
  push     Re-upload the project to the sandbox without running anything.
  pull     Download sandbox artifacts back into the project.
  stop     Stop the sandbox without deleting it.
  down     Delete the sandbox bound to this project.
  help     Show this help.

Environment:
  DAYTONA_API_KEY        Required for any sandbox command.
  DAYTONA_API_URL        Optional Daytona endpoint override.
  FORGE_DAYTONA_SNAPSHOT Optional snapshot name for sandbox creation.
  FORGE_DAYTONA_IMAGE    Optional image override (when no snapshot is given).
  FORGE_REMOTE_WORKDIR   Remote working directory (default: /home/daytona/work).

Examples:
  forge init
  forge init ~/labs/lab3
  forge sync ~/labs/lab3
  forge exec -- g++ -std=c++23 -o build/main src/*.cpp
  forge exec -- bash -lc 'cd docs && typst compile report.typ report.pdf'
  forge shell

After `forge init`:
  1. Complete the Forge `/init` flow in OpenCode.
  2. Add guide.pdf to the project directory.
  3. Run /solve guide.pdf.

EOF
}

die() {
  printf 'forge: %s\n' "$1" >&2
  exit 1
}

target_dir() {
  local path="${1:-.}"

  if [ -d "$path" ]; then
    (cd "$path" && pwd)
  else
    mkdir -p "$path"
    (cd "$path" && pwd)
  fi
}

require_file() {
  local file="$1"

  [ -e "$file" ] || die "required Forge resource not found: $file"
}

copy_file() {
  local src="$1"
  local dst="$2"

  require_file "$src"
  mkdir -p "$(dirname "$dst")"
  cp "$src" "$dst"
}

init_project() {
  local dst_root

  dst_root="$(target_dir "${1:-.}")"

  command -v opencode > /dev/null 2>&1 || die "opencode is required for 'forge init'"

  printf 'Launching OpenCode in: %s\n' "$dst_root"
  printf 'Forge will start with `/init` preloaded.\n'

  exec opencode "$dst_root" --prompt "/init"
}

sync_project() {
  local dst_root

  dst_root="$(target_dir "${1:-.}")"
  mkdir -p "$dst_root/docs"

  copy_file "$FORGE_SHARE_DIR/templates/template.typ" "$dst_root/docs/template.typ"
  copy_file "$FORGE_SHARE_DIR/templates/titlepage.typ" "$dst_root/docs/titlepage.typ"
  copy_file "$FORGE_SHARE_DIR/AGENTS.md.template" "$dst_root/.forge.AGENTS.md.template"
  copy_file "$FORGE_SHARE_DIR/config.example.yaml" "$dst_root/.forge.config.example.yaml"

  cat <<EOF
Forge-managed files refreshed in: $dst_root

Updated:
  - docs/template.typ
  - docs/titlepage.typ
  - .forge.AGENTS.md.template
  - .forge.config.example.yaml
EOF
}

resolve_runtime_dir() {
  if [ -d "$FORGE_SHARE_DIR/runtime" ] && [ -f "$FORGE_SHARE_DIR/runtime/pyproject.toml" ]; then
    printf '%s' "$FORGE_SHARE_DIR/runtime"
    return
  fi
  if [ -f "$FORGE_SHARE_DIR/pyproject.toml" ] && [ -d "$FORGE_SHARE_DIR/forge_runtime" ]; then
    printf '%s' "$FORGE_SHARE_DIR"
    return
  fi
  die "Forge runtime package not found under $FORGE_SHARE_DIR"
}

run_runtime() {
  local runtime_dir
  runtime_dir="$(resolve_runtime_dir)"

  command -v uv > /dev/null 2>&1 || die "uv is required for sandbox commands. Install: https://docs.astral.sh/uv/"

  exec uv run --quiet --project "$runtime_dir" forge-runtime "$@"
}

main() {
  local command="${1:-help}"

  case "$command" in
    init)
      shift || true
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        usage
        return
      fi
      init_project "${1:-.}"
      ;;
    sync)
      shift || true
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        usage
        return
      fi
      sync_project "${1:-.}"
      ;;
    exec)
      shift || true
      run_runtime exec "$@"
      ;;
    shell)
      shift || true
      run_runtime shell "$@"
      ;;
    status|up|push|pull|stop|down)
      local sub="$command"
      shift || true
      case "$sub" in
        push) run_runtime sync "$@" ;;
        *)    run_runtime "$sub" "$@" ;;
      esac
      ;;
    help|--help|-h)
      usage
      ;;
    *)
      die "unknown command: $command"
      ;;
  esac
}

main "$@"
