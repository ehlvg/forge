#!/usr/bin/env bash

set -euo pipefail

FORGE_SHARE_DIR="${FORGE_SHARE_DIR:-__FORGE_SHARE_DIR__}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ ! -d "$FORGE_SHARE_DIR" ]; then
  FORGE_SHARE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
fi

usage() {
  cat <<'EOF'
Forge CLI

Usage:
  forge init [path]
  forge sync [path] [--language russian|english]
  forge help

Commands:
  init   Open OpenCode in the target directory with `/init` preloaded.
  sync   Refresh Forge-managed files in an existing project.
         Updates docs/template.typ and docs/titlepage.typ.
         Language resolved from: --language flag > ./forge.yaml > ~/.forge.yaml > english.
  help   Show this help.

Examples:
  forge init
  forge init ~/labs/lab3
  forge sync ~/labs/lab3
  forge sync ~/labs/lab3 --language russian

After `forge init`:
  1. Complete the Forge `/init` flow in OpenCode.
  2. Add guide.pdf to the project directory.
  3. Run /solve guide.pdf.

EOF
}

die() {
  printf 'forge: %s\n' "$1" >&2
  exit 1
}

target_dir() {
  local path="${1:-.}"

  if [ -d "$path" ]; then
    (cd "$path" && pwd)
  else
    mkdir -p "$path"
    (cd "$path" && pwd)
  fi
}

require_file() {
  local file="$1"

  [ -e "$file" ] || die "required Forge resource not found: $file"
}

copy_file() {
  local src="$1"
  local dst="$2"

  require_file "$src"
  mkdir -p "$(dirname "$dst")"
  cp "$src" "$dst"
}

init_project() {
  local dst_root

  dst_root="$(target_dir "${1:-.}")"

  command -v opencode > /dev/null 2>&1 || die "opencode is required for 'forge init'"

  printf 'Launching OpenCode in: %s\n' "$dst_root"
  printf 'Forge will start with `/init` preloaded.\n'

  exec opencode "$dst_root" --prompt "/init"
}

read_global_language() {
  local global_cfg="${HOME}/.forge.yaml"
  if [ -f "$global_cfg" ]; then
    sed -n '/^language:/s/^language:[[:space:]]*//p' "$global_cfg" | tr -d '"' | tr -d "'"
  fi
}

sync_project() {
  local dst_root
  local lang=""

  # Parse arguments
  while [ $# -gt 0 ]; do
    case "$1" in
      --language)
        shift || true
        lang="${1:-}"
        shift || true
        ;;
      *)
        dst_root="$(target_dir "${1:-.}")"
        shift || true
        ;;
    esac
  done

  : "${dst_root:=$(target_dir ".")}"

  # Resolve language: CLI flag > local forge.yaml > global ~/.forge.yaml > english
  if [ -z "$lang" ]; then
    if [ -f "$dst_root/forge.yaml" ]; then
      lang="$(sed -n '/^language:/s/^language:[[:space:]]*//p' "$dst_root/forge.yaml" | tr -d '"' | tr -d "'")"
    fi
    if [ -z "$lang" ]; then
      lang="$(read_global_language)"
    fi
    : "${lang:=english}"
  fi

  mkdir -p "$dst_root/docs"

  case "$lang" in
    russian|ru)
      copy_file "$FORGE_SHARE_DIR/templates/gost.typ.ru" "$dst_root/docs/template.typ"
      copy_file "$FORGE_SHARE_DIR/templates/titlepage.typ.ru" "$dst_root/docs/titlepage.typ"
      ;;
    english|en|*)
      copy_file "$FORGE_SHARE_DIR/templates/template.typ" "$dst_root/docs/template.typ"
      copy_file "$FORGE_SHARE_DIR/templates/titlepage.typ" "$dst_root/docs/titlepage.typ"
      ;;
  esac
  copy_file "$FORGE_SHARE_DIR/AGENTS.md.template" "$dst_root/.forge.AGENTS.md.template"
  copy_file "$FORGE_SHARE_DIR/config.example.yaml" "$dst_root/.forge.config.example.yaml"

  cat <<EOF
Forge-managed files refreshed in: $dst_root

Language: $lang
Updated:
  - docs/template.typ
  - docs/titlepage.typ
  - .forge.AGENTS.md.template
  - .forge.config.example.yaml
EOF
}

main() {
  local command="${1:-help}"

  case "$command" in
    init)
      shift || true
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        usage
        return
      fi
      init_project "${1:-.}"
      ;;
    sync)
      shift || true
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        usage
        return
      fi
      sync_project "$@"
      ;;
    help|--help|-h)
      usage
      ;;
    *)
      die "unknown command: $command"
      ;;
  esac
}

main "$@"
